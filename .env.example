# Copy this file to .env and fill in your actual values.
# DATABASE_URL should come from the connected Railway Postgres service.
# MEDIA_STORAGE_PATH should point at a persistent Railway volume mount in production.
# MEDIA_SOURCE_PATH should point at the raw local media library on the machine doing the upload.
# API_BASE should be the live site domain that fronts the Railway app service.
# MEDIA_BASE_URL is optional and only needed if media is served from another host/CDN.

DATABASE_URL=your_railway_database_url_here
PORT=8080
MEDIA_STORAGE_PATH=public/clients
MEDIA_BASE_URL=
API_BASE=https://andreafoodstyle.com
MEDIA_SOURCE_PATH=media-source
MEDIA_UPLOAD_CONCURRENCY=2
ENABLE_LOCAL_CONTENT_FALLBACK=true
